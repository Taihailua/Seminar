# ===========================
# CẤU HÌNH DATABASE POSTGRESQL
# ===========================

# Tên người dùng PostgreSQL (mặc định là postgres)
DB_USER=postgres

# Địa chỉ host của database server
DB_HOST=127.0.0.1

# Tên database đã tạo trong PostgreSQL
DB_NAME=Seminar

# Mật khẩu của DB_USER
DB_PASSWORD=123456

# Cổng PostgreSQL (mặc định là 5432)
DB_PORT=5432

# ===========================
# CẤU HÌNH SERVER
# ===========================

# Cổng chạy Express server (mặc định là 3000)
PORT=3000